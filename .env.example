# ═══════════════════════════════════════════════════════════════════════════════
# رائد نيوم - مثال على متغيرات البيئة
# Raed Neom - Environment Variables Example
# ═══════════════════════════════════════════════════════════════════════════════
# انسخ هذا الملف إلى .env وعدّل القيم

# ─────────────────────────────────────────────────────────────────────────────
# قاعدة البيانات
# ─────────────────────────────────────────────────────────────────────────────
DATABASE_URL=file:./db/raed.db

# ─────────────────────────────────────────────────────────────────────────────
# OpenAI API (للنماذج)
# احصل على مفتاح من: https://platform.openai.com/api-keys
# ─────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ─────────────────────────────────────────────────────────────────────────────
# OpenRouter API (بديل OpenAI - يعمل في جميع المناطق)
# احصل على مفتاح من: https://openrouter.ai/keys
# ─────────────────────────────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# ─────────────────────────────────────────────────────────────────────────────
# Telegram Bot (للإشعارات والدعم)
# ─────────────────────────────────────────────────────────────────────────────
# 1. تحدث مع @BotFather على تيليجرام
# 2. أرسل /newbot واتبع التعليمات
# 3. ستحصل على التوكن
TELEGRAM_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# للحصول على Chat ID:
# 1. أضف البوت لمجموعة أو تحدث معه
# 2. زر: https://api.telegram.org/bot<YOUR_TOKEN>/getUpdates
# 3. ابحث عن "chat":{"id":
ADMIN_CHAT_ID=987654321

# ─────────────────────────────────────────────────────────────────────────────
# Backend URL (للتواصل مع الخادم الخلفي)
# ─────────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BACKEND_URL=https://your-backend.onrender.com

# ─────────────────────────────────────────────────────────────────────────────
# Vercel Token (للنشر التلقائي)
# احصل عليه من: https://vercel.com/account/tokens
# ─────────────────────────────────────────────────────────────────────────────
VERCEL_TOKEN=vcp_your-vercel-token-here

# ─────────────────────────────────────────────────────────────────────────────
# GitHub Token (للنشر على GitHub)
# احصل عليه من: https://github.com/settings/tokens
# ─────────────────────────────────────────────────────────────────────────────
GITHUB_TOKEN=ghp_your-github-token-here
